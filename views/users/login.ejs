<% layout("/layouts/boilerplate")%>

<div class="row mt-3">
    <h1 style="text-align: center;">Log In</h1>
    <div class="col-6 offset-3">
        <form action="/login" method="post" class="needs-validation" novalidate>
            <div>
                <label for="username" class="form-label">Username</label>
                <input type="text" placeholder="Ente your name" name="username" class="form-control" required>
            </div>

             <div>
                <label for="password" class="form-label">Password</label>
                <input type="passwords" placeholder="Ente your password" name="password" class="form-control" required>
            </div><br>

            <button class="btn btn-success">Login</button><br><br>
        </form>
    </div>
</div>