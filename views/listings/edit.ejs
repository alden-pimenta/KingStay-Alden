<% layout("/layouts/boilerplate")%>
<body>
    <h3> Edit your listings</h3>
    <form method="post" action="/listings/<%= listing._id %>?_method=put">
        <label for="title" class="form-label"></label>
        <input type="text" value="<%= listing.title %>" name="listing[title]" class="form-control" required>
        <br>
        <label for="discription" class="form-label"></label>
        <textarea type="text" name="listing[description]" class="form-control" ><%= listing.description %></textarea>
        <br>
        <label for="image" class="form-label"></label>
        <input type="text" name="listing[image]" value="<%= listing.image%>" class="form-control" required>
        <br>
        <label for="price" class="form-label"></label>
        <input type="number" name="listing[price]" value="<%= listing.price%>" class="form-control" required>
        <br>
        <label for="country" class="form-label"></label>
        <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control">
        <br>
        <label for="location" class="form-label"></label>
        <input type="location" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
        <br>
        <button class="btn btn-dark" style="margin-bottom: 2rem;">Edit</button>
    </form>
</body>