<% layout("/layouts/boilerplate")%>

    <body>
        <h1 class="new-listing-h1">Create New Listing</h1>
        <form action="/listings" method="post" class="needs-validation" novalidate>

            <div>
                <label for="title" class="form-label">Title</label>

            <input type="text" placeholder="Ente title" name="listing[title]" class="form-control" required>
            <div class="invalid-feedback"> Enter title</div>
            </div>
            
            <br>

            <div>
            <label for="discription" class="form-label">Discription</label>

            <textarea type="text" name="listing[description]" placeholder="Ente discription"
                class="form-control" ></textarea>

            </div>
            <br>

            <div>
                <label for="image" class="form-label">Image</label>
                    <input type="text" name="listing[image][url]" placeholder=" Ente image URL" class="form-control">
            </div>
            <br>

            
            <div class="row">
                <div class="col-md-6">
                    <label for="price" class="form-label">Price</label>

                    <input type="number" name="listing[price]" placeholder="Ente price" class="form-control" required>
                    <div class="invalid-feedback"> Enter a valid input</div>
                    <br>
                </div>
                <div class="col-md-6">
                    <label for="country" class="form-label">Country</label>
                    <input type="text" name="listing[country]" placeholder="Ente country name.." class="form-control" required>
                    <div class="invalid-feedback"> Enter a valid input</div>
                </div>
                 

            </div>

            <br>
            <label for="location" class="form-label"> Location</label>
            <input type="location" name="listing[location]" placeholder="Ente location" class="form-control" required>
            <br>
            <button class="btn btn-dark" style="margin:1rem;">Create</button>
        </form>
    </body>